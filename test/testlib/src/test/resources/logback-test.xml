<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Suppress SLF4J NOP warnings in test output -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Fluss client logging at WARN to reduce noise -->
    <logger name="org.apache.fluss" level="WARN"/>

    <!-- Test framework logging -->
    <logger name="com.knative.fluss.broker" level="INFO"/>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
